@page
@using System.Text.Json
@model Coworking.WebApi.Pages.Rooms.Room
@{
    Layout = "_Layout";
    ViewData["Title"] = "Коворкинг — план помещения";

    // Дата, для которой строится план и временная шкала.
    var planDate = Model.Filter.DateFrom ?? DateOnly.FromDateTime(DateTime.Today);

    // Рабочие часы шкалы
    const int dayStartHour = 9;
    const int dayEndHour   = 22; // не включительно (22:00 — конец последнего слота)

    var jsonOptions = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    // Готовим данные комнат для клиента: id, название, описание, цена, вместимость,
    // удобства и список бронирований (только Start/End — нужны для расчёта занятости).
    var roomsForClient = Model.Rooms.Select(r => new
    {
        id = r.Id,
        name = r.Name,
        description = r.Description,
        price = r.PricePerHour,
        capacity = r.Capacity,
        amenities = r.Amenities ?? new List<string>(),
        bookings = (r.Bookings ?? Enumerable.Empty<dynamic>())
            .Select(b => new { start = (DateTime)b.StartTime, end = (DateTime)b.EndTime })
            .ToList()
    });

    var roomsJson = JsonSerializer.Serialize(roomsForClient, jsonOptions);
}

@section Styles {
    <style>
        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            align-items: end;
            margin-bottom: 1.25rem;
        }
        .filter-bar label {
            display: flex;
            flex-direction: column;
            font-size: .8rem;
            color: #555;
            gap: .25rem;
        }
        .filter-bar input,
        .filter-bar select {
            padding: .4rem .5rem;
            border: 1px solid #ccc;
            border-radius: 6px;
            font-size: .9rem;
        }
        .filter-bar button {
            padding: .5rem 1rem;
            border-radius: 6px;
            border: 1px solid #444;
            background: #fff;
            cursor: pointer;
        }

        .plan-legend {
            display: flex;
            gap: 1.25rem;
            align-items: center;
            margin-bottom: 1rem;
            font-size: .9rem;
            color: #444;
        }
        .legend-swatch {
            display: inline-block;
            width: 14px;
            height: 14px;
            border-radius: 3px;
            margin-right: .35rem;
            vertical-align: middle;
            border: 1px solid rgba(0,0,0,.15);
        }
        .legend-free     { background: #4caf50; }
        .legend-occupied { background: #f44336; }
        .legend-partial  { background: linear-gradient(135deg, #4caf50 50%, #f44336 50%); }

        /* ───────────── 2D floor plan ───────────── */
        .floor-plan {
            display: grid;
            grid-template-columns: repeat(6, minmax(110px, 1fr));
            grid-auto-rows: 90px;
            gap: 10px;
            background: #f4f6f8;
            border: 1px solid #dde2e6;
            border-radius: 12px;
            padding: 16px;
        }
        .room-tile {
            border-radius: 10px;
            border: 2px solid transparent;
            padding: .5rem .6rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            color: #fff;
            cursor: pointer;
            transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
            box-shadow: 0 1px 3px rgba(0,0,0,.15);
            overflow: hidden;
        }
        .room-tile:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,.2);
        }
        .room-tile.selected {
            border-color: #1976d2;
            box-shadow: 0 0 0 3px rgba(25,118,210,.35);
        }
        .room-tile.status-free     { background: #4caf50; }
        .room-tile.status-occupied { background: #f44336; }
        .room-tile.status-partial  {
            background: linear-gradient(135deg, #4caf50 0%, #4caf50 55%, #f44336 55%, #f44336 100%);
        }
        .room-tile .room-name {
            font-weight: 600;
            font-size: .95rem;
            line-height: 1.2;
            text-shadow: 0 1px 2px rgba(0,0,0,.25);
        }
        .room-tile .room-meta {
            font-size: .75rem;
            opacity: .95;
            text-shadow: 0 1px 2px rgba(0,0,0,.25);
        }

        /* size variation based on capacity — gives the grid a "floor plan" feel */
        .room-tile.size-l { grid-column: span 2; grid-row: span 2; }
        .room-tile.size-m { grid-column: span 2; }
        .room-tile.size-s { grid-column: span 1; }

        /* ───────────── Room detail / timeline panel ───────────── */
        .room-panel {
            margin-top: 1.5rem;
            border: 1px solid #dde2e6;
            border-radius: 12px;
            padding: 1rem 1.25rem;
            background: #fff;
            display: none;
        }
        .room-panel.open { display: block; }
        .room-panel h3 { margin: 0 0 .25rem; }
        .room-panel .room-desc { color: #666; font-size: .9rem; margin-bottom: .5rem; }
        .room-panel .room-info {
            display: flex;
            gap: 1.25rem;
            flex-wrap: wrap;
            font-size: .9rem;
            color: #333;
            margin-bottom: .75rem;
        }
        .room-panel .room-info b { color: #111; }

        .timeline-date {
            font-size: .9rem;
            color: #444;
            margin-bottom: .5rem;
        }
        .timeline {
            display: grid;
            grid-template-columns: repeat(13, 1fr);
            gap: 4px;
            margin-bottom: .75rem;
        }
        .slot {
            position: relative;
            border-radius: 6px;
            padding: .5rem .25rem .35rem;
            text-align: center;
            font-size: .75rem;
            color: #fff;
            cursor: pointer;
            border: 2px solid transparent;
            background: #4caf50;
            user-select: none;
        }
        .slot.occupied {
            background: #f44336;
            cursor: not-allowed;
        }
        .slot.selected {
            border-color: #1976d2;
            box-shadow: inset 0 0 0 2px rgba(255,255,255,.6);
        }
        .slot .slot-time { display: block; font-weight: 600; }

        .booking-bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .booking-bar .summary {
            font-size: .9rem;
            color: #333;
        }
        .booking-bar button {
            padding: .55rem 1.25rem;
            border-radius: 6px;
            border: none;
            background: #1976d2;
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }
        .booking-bar button:disabled {
            background: #b0bec5;
            cursor: not-allowed;
        }
        .booking-msg {
            font-size: .85rem;
            margin-top: .5rem;
        }
        .booking-msg.error   { color: #c62828; }
        .booking-msg.success { color: #2e7d32; }

        .empty-state {
            padding: 2rem;
            text-align: center;
            color: #888;
        }
    </style>
}

<h2>Свободные помещения коворкинга</h2>

@* ───────────── Filter form ───────────── *@
<form method="get" class="filter-bar">
    <label>
        Поиск
        <input type="text" name="Filter.Q" value="@Model.Filter.Q" placeholder="название, удобства…" />
    </label>
    <label>
        Цена от
        <input type="number" step="1" min="0" name="Filter.PriceMin" value="@Model.Filter.PriceMin" />
    </label>
    <label>
        Цена до
        <input type="number" step="1" min="0" name="Filter.PriceMax" value="@Model.Filter.PriceMax" />
    </label>
    <label>
        Вместимость от
        <input type="number" step="1" min="1" name="Filter.Capacity" value="@Model.Filter.Capacity" />
    </label>
    <label>
        Дата
        <input type="date" name="Filter.DateFrom" value="@planDate.ToString("yyyy-MM-dd")" />
    </label>
    <label>
        Сортировка
        <select name="Filter.SortBy">
            @{
                var sortOptions = new (string Value, string Label)[]
                {
                    ("newest", "Сначала новые"),
                    ("oldest", "Сначала старые"),
                    ("amenities", "По удобствам"),
                    ("price_asc", "Цена ↑"),
                    ("price_desc", "Цена ↓"),
                    ("capacity", "По вместимости"),
                };
            }
            @foreach (var opt in sortOptions)
            {
                if (Model.Filter.SortBy == opt.Value)
                {
                    <option value="@opt.Value" selected>@opt.Label</option>
                }
                else
                {
                    <option value="@opt.Value">@opt.Label</option>
                }
            }
        </select>
    </label>
    <button type="submit">Применить</button>
</form>

@* ───────────── Legend ───────────── *@
<div class="plan-legend">
    <span><span class="legend-swatch legend-free"></span>Свободна весь день</span>
    <span><span class="legend-swatch legend-partial"></span>Частично занята</span>
    <span><span class="legend-swatch legend-occupied"></span>Занята весь день</span>
    <span>Всего найдено: <b>@Model.TotalCount</b></span>
</div>

@* ───────────── 2D floor plan ───────────── *@
@if (Model.Rooms.Count == 0)
{
    <div class="empty-state">Помещения не найдены — измените параметры фильтра.</div>
}
else
{
    <div class="floor-plan" id="floorPlan"></div>
}

@* ───────────── Room detail / timeline panel ───────────── *@
<div class="room-panel" id="roomPanel">
    <h3 id="rpName"></h3>
    <div class="room-desc" id="rpDescription"></div>
    <div class="room-info">
        <div>Цена: <b id="rpPrice"></b> / час</div>
        <div>Вместимость: <b id="rpCapacity"></b> чел.</div>
        <div>Удобства: <b id="rpAmenities"></b></div>
    </div>

    <div class="timeline-date">
        Доступность на <b id="rpDate"></b> (09:00–22:00). Кликните по свободному слоту,
        затем по конечному, чтобы выбрать интервал.
    </div>
    <div class="timeline" id="rpTimeline"></div>

    <div class="booking-bar">
        <div class="summary" id="rpSummary">Выберите время бронирования.</div>
        <button id="rpBookBtn" disabled>Забронировать</button>
    </div>
    <div class="booking-msg" id="rpMsg"></div>
</div>

@* ───────────── Antiforgery token for AJAX POST ───────────── *@
<form id="antiForgeryForm" style="display:none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        (function () {
            const rooms = @Html.Raw(roomsJson);
            const planDate = "@planDate.ToString("yyyy-MM-dd")";
            const DAY_START = @dayStartHour;
            const DAY_END = @dayEndHour;

            const floorPlanEl = document.getElementById('floorPlan');
            const panelEl = document.getElementById('roomPanel');
            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');

            let selectedRoom = null;
            let selStart = null; // selected start slot index
            let selEnd = null;   // selected end slot index (exclusive)

            // ── helpers ────────────────────────────────────────────
            function hourLabel(h) {
                return String(h).padStart(2, '0') + ':00';
            }

            // Returns array of booleans: true = free, for hours [DAY_START, DAY_END)
            function slotAvailability(room) {
                const slots = [];
                for (let h = DAY_START; h < DAY_END; h++) {
                    const slotStart = new Date(planDate + 'T' + String(h).padStart(2, '0') + ':00:00');
                    const slotEnd = new Date(slotStart.getTime() + 60 * 60 * 1000);
                    const occupied = (room.bookings || []).some(b => {
                        const bs = new Date(b.start);
                        const be = new Date(b.end);
                        return bs < slotEnd && be > slotStart;
                    });
                    slots.push(!occupied);
                }
                return slots;
            }

            function roomStatusClass(slots) {
                const freeCount = slots.filter(Boolean).length;
                if (freeCount === slots.length) return 'status-free';
                if (freeCount === 0) return 'status-occupied';
                return 'status-partial';
            }

            function sizeClass(capacity) {
                if (capacity >= 8) return 'size-l';
                if (capacity >= 4) return 'size-m';
                return 'size-s';
            }

            // ── render floor plan ─────────────────────────────────
            function renderFloorPlan() {
                floorPlanEl.innerHTML = '';
                rooms.forEach(room => {
                    const slots = slotAvailability(room);
                    const tile = document.createElement('div');
                    tile.className = 'room-tile ' + roomStatusClass(slots) + ' ' + sizeClass(room.capacity);
                    tile.dataset.roomId = room.id;
                    tile.innerHTML =
                        '<div class="room-name">' + escapeHtml(room.name) + '</div>' +
                        '<div class="room-meta">' + room.price + ' ₸/ч · до ' + room.capacity + ' чел.</div>';
                    tile.addEventListener('click', () => selectRoom(room, tile));
                    floorPlanEl.appendChild(tile);
                });
            }

            function escapeHtml(str) {
                const div = document.createElement('div');
                div.textContent = str ?? '';
                return div.innerHTML;
            }

            // ── room panel / timeline ───────────────────────────────
            function selectRoom(room, tile) {
                document.querySelectorAll('.room-tile.selected').forEach(t => t.classList.remove('selected'));
                tile.classList.add('selected');

                selectedRoom = room;
                selStart = null;
                selEnd = null;

                document.getElementById('rpName').textContent = room.name;
                document.getElementById('rpDescription').textContent = room.description || '';
                document.getElementById('rpPrice').textContent = room.price;
                document.getElementById('rpCapacity').textContent = room.capacity;
                document.getElementById('rpAmenities').textContent =
                    (room.amenities && room.amenities.length) ? room.amenities.join(', ') : '—';
                document.getElementById('rpDate').textContent = planDate;
                document.getElementById('rpMsg').textContent = '';
                document.getElementById('rpMsg').className = 'booking-msg';

                renderTimeline();
                updateSummary();
                panelEl.classList.add('open');
                panelEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            function renderTimeline() {
                const timelineEl = document.getElementById('rpTimeline');
                timelineEl.innerHTML = '';
                const slots = slotAvailability(selectedRoom);

                slots.forEach((free, idx) => {
                    const hour = DAY_START + idx;
                    const slotEl = document.createElement('div');
                    slotEl.className = 'slot' + (free ? '' : ' occupied');
                    slotEl.innerHTML = '<span class="slot-time">' + hourLabel(hour) + '</span>';
                    if (free) {
                        slotEl.addEventListener('click', () => onSlotClick(idx));
                    }
                    timelineEl.appendChild(slotEl);
                });

                highlightSelection();
            }

            function onSlotClick(idx) {
                const slots = slotAvailability(selectedRoom);

                if (selStart === null) {
                    selStart = idx;
                    selEnd = idx + 1;
                } else if (selEnd !== null && idx + 1 === selEnd && idx === selStart) {
                    // clicking the same single slot again clears selection
                    selStart = null;
                    selEnd = null;
                } else {
                    const lo = Math.min(selStart, idx);
                    const hi = Math.max(selStart, idx);

                    // ensure every slot in [lo, hi] is free (contiguous, no occupied gaps)
                    let allFree = true;
                    for (let i = lo; i <= hi; i++) {
                        if (!slots[i]) { allFree = false; break; }
                    }

                    if (allFree) {
                        selStart = lo;
                        selEnd = hi + 1;
                    } else {
                        // start a new selection from the clicked slot
                        selStart = idx;
                        selEnd = idx + 1;
                    }
                }

                highlightSelection();
                updateSummary();
            }

            function highlightSelection() {
                const timelineEl = document.getElementById('rpTimeline');
                Array.from(timelineEl.children).forEach((el, idx) => {
                    if (selStart !== null && idx >= selStart && idx < selEnd) {
                        el.classList.add('selected');
                    } else {
                        el.classList.remove('selected');
                    }
                });
            }

            function updateSummary() {
                const summaryEl = document.getElementById('rpSummary');
                const btn = document.getElementById('rpBookBtn');

                if (selStart === null) {
                    summaryEl.textContent = 'Выберите время бронирования.';
                    btn.disabled = true;
                    return;
                }

                const startHour = DAY_START + selStart;
                const endHour = DAY_START + selEnd;
                const hours = selEnd - selStart;
                const total = (selectedRoom.price * hours).toFixed(0);

                summaryEl.innerHTML =
                    'Время: <b>' + hourLabel(startHour) + ' – ' + hourLabel(endHour) + '</b>' +
                    ' (' + hours + ' ч) · Итого: <b>' + total + ' ₸</b>';
                btn.disabled = false;
            }

            // ── booking submission ──────────────────────────────────
            document.getElementById('rpBookBtn').addEventListener('click', async () => {
                if (!selectedRoom || selStart === null) return;

                const startHour = DAY_START + selStart;
                const endHour = DAY_START + selEnd;

                const startTime = planDate + 'T' + String(startHour).padStart(2, '0') + ':00:00';
                const endTime = planDate + 'T' + String(endHour).padStart(2, '0') + ':00:00';

                const btn = document.getElementById('rpBookBtn');
                const msgEl = document.getElementById('rpMsg');
                btn.disabled = true;
                msgEl.textContent = 'Отправка…';
                msgEl.className = 'booking-msg';

                try {
                    const response = await fetch('?handler=Create', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenInput ? tokenInput.value : ''
                        },
                        body: JSON.stringify({
                            roomId: selectedRoom.id,
                            startTime: startTime,
                            endTime: endTime
                        })
                    });

                    const data = await response.json();

                    if (data.success) {
                        msgEl.textContent = 'Бронирование подтверждено!';
                        msgEl.className = 'booking-msg success';
                        // add the new booking locally so the plan/timeline update immediately
                        selectedRoom.bookings.push({ start: startTime, end: endTime });
                        selStart = null;
                        selEnd = null;
                        renderFloorPlan();
                        renderTimeline();
                        updateSummary();
                        // re-mark this room as selected
                        const tile = floorPlanEl.querySelector('[data-room-id="' + selectedRoom.id + '"]');
                        if (tile) tile.classList.add('selected');
                    } else {
                        msgEl.textContent = data.message || 'Не удалось создать бронирование.';
                        msgEl.className = 'booking-msg error';
                        btn.disabled = false;
                    }
                } catch (e) {
                    msgEl.textContent = 'Ошибка сети. Попробуйте ещё раз.';
                    msgEl.className = 'booking-msg error';
                    btn.disabled = false;
                }
            });

            renderFloorPlan();
        })();
    </script>
}
