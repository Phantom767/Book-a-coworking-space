@page
@model Coworking.WebApi.Pages.IndexModel
@{
    ViewData["Title"] = Localizer["HeroTitle"];
    Layout = "_Layout";
}

@section Styles {
    <style>
        .hero {
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
            padding: 100px 0 80px;
            position: relative;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .hover-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.2) !important;
        }
        .icon-box {
            width: 70px;
            height: 70px;
            background-color: rgba(108, 92, 231, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}

<div class="hero">
    <div class="container text-center">
        <!-- Используем Localizer["Key"] -->
        <h1 class="display-3 fw-bold mb-3 text-white">@Localizer["HeroTitle"]</h1>
        <p class="fs-5 text-light opacity-75 mx-auto" style="max-width: 700px; color: #ffffff">
            @Localizer["HeroSubtitle"]
        </p>
    </div>
</div>

<!-- Секция Преимуществ -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-white">@Localizer["WhyUsTitle"]</h2>
            <p class="text-secondary">@Localizer["WhyUsSubtitle"]</p>
        </div>

        <div class="row g-4">
            <!-- Карточка 1: Интернет -->
            <div class="col-md-4">
                <div class="card h-100 hover-card p-3">
                    <div class="card-body text-center">
                        <div class="icon-box rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#6c5ce7" class="bi bi-wifi" viewBox="0 0 16 16">
                                <path d="M15.384 6.115a.485.485 0 0 0-.047-.736A12.444 12.444 0 0 0 8 3C5.259 3 2.723 3.882.663 5.379a.485.485 0 0 0-.048.736.518.518 0 0 0 .668.05A11.448 11.448 0 0 1 8 4c2.507 0 4.827.802 6.716 2.164.205.148.49.13.668-.049z"/>
                                <path d="M13.229 8.271a.482.482 0 0 0-.063-.745A9.456 9.456 0 0 0 8 6c-1.905 0-3.68.56-5.166 1.526a.48.48 0 0 0-.063.745.525.525 0 0 0 .652.065A8.46 8.46 0 0 1 8 7a8.46 8.46 0 0 1 4.576 1.336c.206.132.48.108.653-.065zm-2.183 2.183c.207.132.48.108.653-.065a.482.482 0 0 0-.063-.745A6.47 6.47 0 0 0 8 9c-1.12 0-2.16.32-3.04.875a.48.48 0 0 0-.063.745.525.525 0 0 0 .652.065A5.47 5.47 0 0 1 8 10a5.47 5.47 0 0 1 3.046.954zM8 13a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                            </svg>
                        </div>
                        <h5 class="card-title fw-bold">@Localizer["FeatureInternetTitle"]</h5>
                        <p class="card-text">@Localizer["FeatureInternetDesc"]</p>
                    </div>
                </div>
            </div>

            <!-- Карточка 2: Кофе -->
            <div class="col-md-4">
                <div class="card h-100 hover-card p-3">
                    <div class="card-body text-center">
                        <div class="icon-box rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#6c5ce7" class="bi bi-cup-hot" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M2.5 11.5A.5.5 0 0 1 3 11h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 3 9h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 3 7h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 3 5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                                <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-1v5a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6H2a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v2h10V2a1 1 0 0 0-1-1H4z"/>
                            </svg>
                        </div>
                        <h5 class="card-title fw-bold">@Localizer["FeatureCoffeeTitle"]</h5>
                        <p class="card-text">@Localizer["FeatureCoffeeDesc"]</p>
                    </div>
                </div>
            </div>

            <!-- Карточка 3: Комьюнити -->
            <div class="col-md-4">
                <div class="card h-100 hover-card p-3">
                    <div class="card-body text-center">
                        <div class="icon-box rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#6c5ce7" class="bi bi-people" viewBox="0 0 16 16">
                                <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816zM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275zM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0zm3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
                            </svg>
                        </div>
                        <h5 class="card-title fw-bold">@Localizer["FeatureCommunityTitle"]</h5>
                        <p class="card-text">@Localizer["FeatureCommunityDesc"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>