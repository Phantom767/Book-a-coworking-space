@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card bg-dark text-white border-secondary">
                <div class="card-body p-4">
                    <h2 class="card-title mb-4 text-center">@Localizer["CardTitle"]</h2>
                    
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    else
                    {
                        <p class="text-muted mb-4">@Localizer["InstructionText"]</p>

                        <form method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3"></div>
                            
                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label">@Localizer["EmailLabel"]</label>
                                <input asp-for="Input.Email" class="form-control bg-secondary text-white border-0" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">@Localizer["SubmitButton"]</button>
                        </form>
                    }
                    
                    <div class="text-center mt-3">
                        <a asp-page="./Login" class="text-decoration-none">@Localizer["BackToLogin"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>