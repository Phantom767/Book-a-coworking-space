@page
@model Coworking.WebApi.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card bg-dark text-white border-secondary">
                <div class="card-body p-4">
                    <h2 class="card-title mb-4 text-center">@Localizer["CardTitle"]</h2>

                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        
                        <input asp-for="Input.Code" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">@Localizer["EmailLabel"]</label>
                            <input asp-for="Input.Email" class="form-control bg-secondary text-white border-0" readonly />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3 position-relative">
                            <label asp-for="Input.Password" class="form-label">@Localizer["PasswordLabel"]</label>
                            <div class="input-group">
                                <input asp-for="Input.Password" type="password" class="form-control bg-secondary text-white border-0" id="newPassword" placeholder="@Localizer["PasswordPlaceholder"]" />
                                <button class="btn btn-outline-secondary border-0 text-white" type="button" onclick="togglePassword('newPassword', this)">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4 position-relative">
                            <label asp-for="Input.ConfirmPassword" class="form-label">@Localizer["ConfirmPasswordLabel"]</label>
                            <div class="input-group">
                                <input asp-for="Input.ConfirmPassword" type="password" class="form-control bg-secondary text-white border-0" id="newConfirmPassword" placeholder="@Localizer["ConfirmPasswordPlaceholder"]" />
                                <button class="btn btn-outline-secondary border-0 text-white" type="button" onclick="togglePassword('newConfirmPassword', this)">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">@Localizer["SubmitButton"]</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const icon = button.querySelector('i');
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            } else {
                input.type = "password";
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            }
        }
    </script>
}